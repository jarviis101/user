# GraphQL schema example
#
# https://gqlgen.com/getting-started/

type User {
    id: ID!
    firstName: String!
    lastName: String!
    email: String!
    phone: String!
    createdAt: String!
    updatedAt: String!
}

type Query {
    users(page: Int = 1, itemsPerPage: Int = 10): [User]!
    user(id: ID!): User
}

input CreateUser {
    firstName: String!
    lastName: String!
    email: String!
    phone: String!
}

type Mutation {
    createUser(input: CreateUser!): User!
}
